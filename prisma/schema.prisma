generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Plan {
  free
  premium
}

enum SkillLevel {
  podstawowy
  sredni
  zaawansowany
  ekspert
}

enum LanguageLevel {
  A1
  A2
  B1
  B2
  C1
  C2
  native
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  fullName     String   @map("full_name")
  phone        String?
  plan         Plan     @default(free)
  // Premium subscription current period end — plan is only "aktywny" while this
  // is in the future. Kept separate from `plan` so an expired subscription can
  // fall back to free without losing the historical enum value.
  planRenewsAt DateTime? @map("plan_renews_at")
  // Explicit flag rather than deriving "free generation used" from
  // generatedCvs.count() > 0 — avoids retroactively penalizing accounts that
  // already had CVs before this paywall existed (defaults to false on migrate).
  freeGenerationUsed Boolean @default(false) @map("free_generation_used")
  // Remaining one-off "pakiet" credits (2 per 5 zł), decremented per generation
  // once the free generation and any active subscription don't apply.
  purchasedCredits   Int     @default(0) @map("purchased_credits")
  // Set true on any successful purchase (subscription or package) — unlocks CV
  // history permanently, independent of current credit balance or whether a
  // subscription later lapses.
  hasEverPurchased   Boolean @default(false) @map("has_ever_purchased")
  // Null until the user clicks the link in their verification email. Gates
  // the free-tier generation allowance — without this, someone could script
  // unlimited disposable-email registrations to get unlimited free CVs, each
  // one a real Claude API cost. Existing accounts are backfilled to their
  // createdAt on migration so nobody already using the app gets locked out.
  emailVerifiedAt    DateTime? @map("email_verified_at")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  profile                  Profile?
  jobPostings              JobPosting[]
  generatedCvs             GeneratedCv[]
  generatedCoverLetters    GeneratedCoverLetter[]
  passwordResetTokens      PasswordResetToken[]
  emailVerificationTokens  EmailVerificationToken[]

  @@map("users")
}

model EmailVerificationToken {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("email_verification_tokens")
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

model Profile {
  id          String   @id @default(uuid())
  userId      String   @unique @map("user_id")
  headline    String?
  summary     String?
  location    String?
  phone       String?
  photoUrl    String?  @map("photo_url")
  linkedinUrl String?  @map("linkedin_url")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  experiences Experience[]
  education   Education[]
  skills      Skill[]
  interests   Interest[]
  languages   Language[]

  @@map("profiles")
}

model Language {
  id         String        @id @default(uuid())
  profileId  String        @map("profile_id")
  name       String
  level      LanguageLevel
  orderIndex Int           @default(0) @map("order_index")

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@map("languages")
}

model Experience {
  id          String    @id @default(uuid())
  profileId   String    @map("profile_id")
  companyName String    @map("company_name")
  position    String
  description String?
  startDate   DateTime  @map("start_date")
  endDate     DateTime? @map("end_date")
  orderIndex  Int       @default(0) @map("order_index")

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@map("experiences")
}

model Education {
  id         String    @id @default(uuid())
  profileId  String    @map("profile_id")
  schoolName String    @map("school_name")
  degree     String?
  startDate  DateTime  @map("start_date")
  endDate    DateTime? @map("end_date")

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@map("education")
}

model Skill {
  id        String      @id @default(uuid())
  profileId String      @map("profile_id")
  name      String
  level     SkillLevel?
  category  String?

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@map("skills")
}

model Interest {
  id        String @id @default(uuid())
  profileId String @map("profile_id")
  name      String

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@map("interests")
}

model JobPosting {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  sourceUrl   String?  @map("source_url")
  rawContent  String   @map("raw_content")
  companyName String?  @map("company_name")
  jobTitle    String?  @map("job_title")
  createdAt   DateTime @default(now()) @map("created_at")

  user               User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  generatedCvs       GeneratedCv[]
  generatedCoverLetters GeneratedCoverLetter[]

  @@map("job_postings")
}

model GeneratedCv {
  id            String   @id @default(uuid())
  userId        String   @map("user_id")
  jobPostingId  String   @map("job_posting_id")
  contentJson   Json     @map("content_json")
  templateId    String   @map("template_id")
  version       Int      @default(1)
  createdAt     DateTime @default(now()) @map("created_at")

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobPosting JobPosting @relation(fields: [jobPostingId], references: [id], onDelete: Cascade)

  @@map("generated_cvs")
}

// Premium-only feature — see lib/plan.ts isPremiumActive() gate in the API route.
model GeneratedCoverLetter {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  jobPostingId String   @map("job_posting_id")
  contentJson  Json     @map("content_json")
  createdAt    DateTime @default(now()) @map("created_at")

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobPosting JobPosting @relation(fields: [jobPostingId], references: [id], onDelete: Cascade)

  @@map("generated_cover_letters")
}
